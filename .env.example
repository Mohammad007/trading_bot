# ============================================================
# AI MULTI-CHAIN SNIPER  -  ENVIRONMENT CONFIGURATION
# ============================================================
# Copy to ".env" and fill in. Do NOT commit .env to git.
# ============================================================

# ---- TRADING MODE ----
# PAPER (default, safe) or REAL
MODE=PAPER
ENABLE_REAL_TRADING=false

# Which chains should the bot scan?  Comma-separated.
# Available: solana, ethereum, bsc, polygon, base, arbitrum, optimism, avalanche, tron
ENABLED_CHAINS=solana,bsc,polygon,base,arbitrum,optimism,avalanche,tron

# ============================================================
# SOLANA
# ============================================================
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

HELIUS_API_KEY=
QUICKNODE_RPC_URL=

# Solana wallet (REAL mode). Base58 (Phantom export).
WALLET_PRIVATE_KEY=
WALLET_PRIVATE_KEY_ENC=
WALLET_ENC_PASSPHRASE=
EXTRA_WALLETS=

# Smart wallets to copy-trade (comma-separated Solana addresses)
SMART_WALLETS=

# ============================================================
# EVM (Ethereum, BSC, Polygon, Base, Arbitrum, Optimism, Avalanche)
# ============================================================
# Per-chain HTTP RPC. Use Alchemy/Infura/QuickNode for prod.
ETHEREUM_RPC_URL=https://eth.llamarpc.com
BSC_RPC_URL=https://bsc-dataseed.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com
BASE_RPC_URL=https://mainnet.base.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Backup RPC pool (comma-separated per chain). Used for failover.
ETHEREUM_RPC_FALLBACKS=https://rpc.ankr.com/eth
BSC_RPC_FALLBACKS=https://bsc.publicnode.com
POLYGON_RPC_FALLBACKS=https://polygon.llamarpc.com
BASE_RPC_FALLBACKS=https://base.llamarpc.com
ARBITRUM_RPC_FALLBACKS=https://arbitrum.llamarpc.com
OPTIMISM_RPC_FALLBACKS=https://optimism.llamarpc.com
AVALANCHE_RPC_FALLBACKS=https://avalanche.public-rpc.com

# WebSocket endpoints for new-pair sniper (set at least one).
ETHEREUM_WS_URL=
BSC_WS_URL=
POLYGON_WS_URL=
BASE_WS_URL=
ARBITRUM_WS_URL=
OPTIMISM_WS_URL=
AVALANCHE_WS_URL=

# EVM wallet (REAL mode)
EVM_PRIVATE_KEY=
EVM_PRIVATE_KEY_ENC=

# ============================================================
# TRON
# ============================================================
TRONGRID_API_KEY=
TRON_PRIVATE_KEY=

# ============================================================
# PAPER WALLET
# ============================================================
PAPER_STARTING_BALANCE_USDT=100

# Paper-mode realism. "full" (default) simulates real Solana execution:
#   - slippage (depth-based)
#   - base + priority gas fees deducted
#   - ~5% random tx failure rate
#   - 0.6-2.2s execution latency
# Use "instant" only for idealized strategy testing - paper PnL with
# "instant" will be wildly optimistic vs REAL mode.
PAPER_SIMULATION_REALISM=full

# ============================================================
# TRADING PARAMETERS (chain-agnostic)
# ============================================================
DEFAULT_BUY_AMOUNT_SOL=0.05
MAX_OPEN_POSITIONS=5
MAX_DAILY_LOSS_USDT=20
COOLDOWN_AFTER_LOSS_SECS=120

SLIPPAGE_BPS=300
PRIORITY_FEE_MICROLAMPORTS=200000

TAKE_PROFIT=0.50
STOP_LOSS=0.20
TRAILING_STOP=0.15

AI_BUY_THRESHOLD=0.65
AI_SELL_THRESHOLD=0.35

# ---- SCALP MODE (aggressive fast-exit) ----
# When SCALP_MODE=true, the bot ignores TAKE_PROFIT / STOP_LOSS / trailing /
# chart-AI exits and only uses these rules:
#   - exit on  profit_pct >= SCALP_PROFIT_PCT   (e.g. 0.02 = +2%)
#   - exit on  profit_usd >= SCALP_PROFIT_USD   (e.g. 1.0  = +$1)
#   - safety:  exit on loss >= SCALP_MAX_LOSS_PCT (account-blowup guard)
#
# WARNING: +1% gross usually = negative after AMM slippage + gas. +2% gross
# is a more realistic "scalp" target on Solana.
SCALP_MODE=false
SCALP_PROFIT_PCT=0.03         # 3% TP - leaves ~2% after slippage
SCALP_PROFIT_USD=1.0
SCALP_MAX_LOSS_PCT=0.08       # -8% stop - keeps risk:reward viable

# ---- SMART PROFIT LOCK ("human scalper" trailing) ----
# Once price is in profit by SMART_LOCK_ARM_PCT, the bot watches the peak.
# The moment price retraces SMART_LOCK_RETRACE_PCT from that peak it exits
# with whatever profit is left, rather than waiting for the bigger TP.
# This catches many small consistent wins ("scared money" but smart).
# Only active when SCALP_MODE=true.
SMART_PROFIT_LOCK=true
SMART_LOCK_ARM_PCT=0.005      # 0.5% - minimum profit before lock arms
SMART_LOCK_RETRACE_PCT=0.003  # 0.3% - pullback from peak triggers exit

# ============================================================
# DEX bases
# ============================================================
DEXSCREENER_BASE=https://api.dexscreener.com
RAYDIUM_BASE=https://api.raydium.io
PUMPFUN_BASE=https://frontend-api.pump.fun
JUPITER_BASE=https://quote-api.jup.ag/v6

# ============================================================
# TELEGRAM
# ============================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
